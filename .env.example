# Copy this file to .env and fill in real values.
# Every variable below is read in quiz_portal/settings.py - confirmed by
# grepping the entire codebase for os.environ.get()/config() calls, so this
# list should be complete.

# --- Server ---
WebServer_Port=8001

# --- Django ---
# Generate a new one - do not reuse any default that may exist in this
# project's settings.py / git history:
#   python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-generate-a-real-secret-key

# --- Database (Postgres) ---
# These match the hardcoded defaults already in settings.py, used as a
# fallback if these vars aren't set. Override them here for anything beyond
# local throwaway testing, especially DB_PASSWORD.
DB_NAME=quiz_portal
DB_USER=quiz_user
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5433

# --- Email (OTP / password reset) ---
# A Gmail App Password, not your regular account password
# (https://myaccount.google.com/apppasswords)
EMAIL_HOST_PASSWORD=

# --- Google OAuth (social login) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Not env vars, but also required for full functionality ---
# These are files, not variables - place them at the paths below if you want
# push notifications working. The app boots fine without them; push
# notifications are just disabled until they're present.
#   credentials.json              <- project root (Firebase Admin SDK)
#   config/serviceAccountKey.json <- config/ folder (FCM)
